# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# research PDFs (large binary files)
research/**/*.pdf

# python
__pycache__/

# backup/derived files in public data
public/data/*.bak

# AI coding tools (local dev environment)
.agents/
.claude/
.kiro/
.trae/

# HSCninja scraped data (do NOT commit)
data/hscninja/
scripts/scrape-hscninja.mjs
